# ============================================
# Environment Configuration for Monarch
# ============================================
# Copy this file to .env.local and fill in values
# Do not commit .env files to git

# ============================================
# Application Configuration
# ============================================
VITE_APP_ID=your_app_id_here

# ============================================
# Authentication & Security
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_at_least_32_characters

# ============================================
# Database Configuration
# ============================================
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/monarch

# ============================================
# OAuth & Authentication Server
# ============================================
OAUTH_SERVER_URL=https://oauth-server-url.com
OWNER_OPEN_ID=your_owner_open_id

# ============================================
# Voice Transcription Service (Optional)
# ============================================
BUILT_IN_FORGE_API_URL=https://forge-api.example.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# ============================================
# Runtime Environment
# ============================================
NODE_ENV=development
PORT=3000
